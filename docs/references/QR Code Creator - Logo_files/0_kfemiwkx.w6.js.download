        .logoDesign{
          .scroll-content {
            height: 230px;
            padding-top: 8px;
          }

          .scrollbar-track-y {
            width: 4px;
            margin-top: 8px;
            .scrollbar-thumb {
              width: 4px;
              background: var(--color-success);
            }
          }


          .rs-slider-bar {
            background-color: #e0e0e0;
          }

          .rs-slider-progress-bar {
            background-color: var(--color-success);
          }

          .rs-slider-tooltip {
            display: none !important;
          }

          .rs-slider-handle {
            margin-top: -12px;
            position: relative;
            width: 18px;
            height: 18px;

            &:before {
              width: 18px;
              height: 18px;
              background-color: var(--color-success);
              border: none;
              box-shadow: unset;
              transform: scale(1);
            }

            &:after {
              position: absolute;
              content: "";
              width: 6px;
              height: 6px;
              top: 50%;
              transform: translateY(-50%);
              background-color: #fff;
              border-radius: 100%;
            }
          }
        }

