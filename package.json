{
  "name": "qurl",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "bootstrap": "corepack enable && pnpm install",
    "build:web": "pnpm --filter @qurl/web run build",
    "build:backend": "node ./scripts/build-backend.mjs",
    "check": "pnpm run lint && pnpm run test && pnpm run typecheck && pnpm run format:check && pnpm run check:contracts && pnpm run check:backend",
    "check:backend": "node ./scripts/check-backend.mjs",
    "check:contracts": "node ./scripts/check-contracts.mjs",
    "dev": "pnpm run dev:docker",
    "dev:backend": "node ./scripts/dev-backend.mjs",
    "dev:docker": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "dev:docker:prod": "docker compose up --build",
    "dev:local": "pnpm run dev:web",
    "dev:web": "pnpm --filter @qurl/web dev",
    "docker:down": "docker compose down",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}