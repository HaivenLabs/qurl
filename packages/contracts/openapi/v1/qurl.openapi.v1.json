{
  "openapi": "3.1.0",
  "info": {
    "title": "qurl API",
    "version": "1.0.0",
    "description": "Versioned contract surface for qurl QR creation, validation, preview, and saved project operations."
  },
  "servers": [
    {
      "url": "/api/v1"
    }
  ],
  "paths": {
    "/direct-url/preview": {
      "post": {
        "operationId": "previewDirectUrl",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QrProjectConfigV1"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SVG preview payload for the direct destination QR.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "schemaVersion",
                    "destination",
                    "format",
                    "mimeType",
                    "svg",
                    "dataUrl"
                  ],
                  "properties": {
                    "schemaVersion": {
                      "type": "integer",
                      "const": 1
                    },
                    "destination": {
                      "type": "string"
                    },
                    "format": {
                      "type": "string",
                      "const": "svg"
                    },
                    "mimeType": {
                      "type": "string",
                      "const": "image/svg+xml"
                    },
                    "svg": {
                      "type": "string"
                    },
                    "dataUrl": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/direct-url/export": {
      "post": {
        "operationId": "exportDirectUrl",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QrProjectConfigV1"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rendered QR export bytes.",
            "content": {
              "image/svg+xml": {
                "schema": {
                  "type": "string"
                }
              },
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "QrPayloadConfigV1": {
        "$ref": "../../schemas/v1/qr-payload-config.v1.schema.json"
      },
      "QrDesignConfigV1": {
        "$ref": "../../schemas/v1/qr-design-config.v1.schema.json"
      },
      "QrExportConfigV1": {
        "$ref": "../../schemas/v1/qr-export-config.v1.schema.json"
      },
      "QrProjectConfigV1": {
        "$ref": "../../schemas/v1/qr-project-config.v1.schema.json"
      },
      "QrTypeRegistryV1": {
        "$ref": "../../schemas/v1/qr-type-registry.v1.schema.json"
      },
      "ValidationIssueV1": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "code", "severity", "message"],
        "properties": {
          "path": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["error", "warning"]
          },
          "message": {
            "type": "string"
          }
        }
      },
      "QrProjectValidationResponseV1": {
        "type": "object",
        "additionalProperties": false,
        "required": ["valid", "issues"],
        "properties": {
          "valid": {
            "type": "boolean"
          },
          "issues": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ValidationIssueV1"
            }
          }
        }
      },
      "QrPreviewResponseV1": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mimeType", "preview", "warnings"],
        "properties": {
          "mimeType": {
            "type": "string",
            "const": "image/svg+xml"
          },
          "preview": {
            "type": "string"
          },
          "warnings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ValidationIssueV1"
            }
          }
        }
      },
      "QrProjectRecordV1": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "projectId",
          "schemaVersion",
          "name",
          "payload",
          "design",
          "export",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "projectId": {
            "type": "string"
          },
          "schemaVersion": {
            "type": "string",
            "const": "qurl.qr-project-config.v1"
          },
          "name": {
            "type": "string"
          },
          "payload": {
            "$ref": "#/components/schemas/QrPayloadConfigV1"
          },
          "design": {
            "$ref": "#/components/schemas/QrDesignConfigV1"
          },
          "export": {
            "$ref": "#/components/schemas/QrExportConfigV1"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "QrExportArtifactV1": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifactId", "format", "downloadUrl", "fileName"],
        "properties": {
          "artifactId": {
            "type": "string"
          },
          "format": {
            "type": "string",
            "enum": ["png", "svg"]
          },
          "downloadUrl": {
            "type": "string",
            "format": "uri"
          },
          "fileName": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
