{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qurl.dev/schemas/qr-project-config.v1.schema.json",
  "title": "QR Project Config v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "name", "payload", "design", "export"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "qurl.qr-project-config.v1"
    },
    "projectId": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "saved", "archived"]
    },
    "favorite": {
      "type": "boolean"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "payload": {
      "$ref": "qr-payload-config.v1.schema.json"
    },
    "design": {
      "$ref": "qr-design-config.v1.schema.json"
    },
    "export": {
      "$ref": "qr-export-config.v1.schema.json"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
